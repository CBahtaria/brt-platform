# BRT Platform — Client Deployment Configuration
# Copy this to .env and fill in values before deploying

BRT_TENANT_ID=REPLACE_WITH_CLIENT_TENANT_ID
BRT_ENV=production
DEBUG=false

# LLM (required for generation)
ANTHROPIC_API_KEY=

# Qdrant — managed by docker-compose, no changes needed
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Redis — managed by docker-compose
REDIS_URL=redis://redis:6379/0

# Operator alerting (optional but recommended)
WHATSAPP_GATEWAY_URL=
CONSULTANT_WHATSAPP_NUMBER=

# Supabase (optional — for multi-tenant auth in Phase 1+)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Kafka KRaft (generate: podman run --rm bitnami/kafka:3.6 kafka-storage.sh random-uuid)
KAFKA_KRAFT_CLUSTER_ID=
