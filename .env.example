# BRT Platform Configuration
BRT_TENANT_ID=brt-default
BRT_ENV=production
DEBUG=false

# Anthropic (LLM)
ANTHROPIC_API_KEY=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Redis
REDIS_URL=redis://localhost:6379/0

# ClickHouse (Project B — analytics)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_DB=brt_platform
CLICKHOUSE_USER=brt_user
CLICKHOUSE_PASSWORD=

# Kafka (Project B — analytics)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# Generate: podman run --rm bitnami/kafka:3.6 kafka-storage.sh random-uuid
KAFKA_KRAFT_CLUSTER_ID=

# Paystack (Project B — gated on SA entity registration)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# WhatsApp Alerting (direct httpx — NOT brt_platform.plugins.connectors.whatsapp)
WHATSAPP_GATEWAY_URL=
CONSULTANT_WHATSAPP_NUMBER=

# Slack
SLACK_WEBHOOK_URL=
SLACK_DEPLOY_WEBHOOK=

# S3/MinIO
S3_ENDPOINT=
S3_BUCKET=brt-platform-artifacts
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Supabase (shared with brt-inc website)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
